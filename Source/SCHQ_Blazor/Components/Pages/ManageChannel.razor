@page "/managechannel/{ChannelName}"
@page "/addchannel"
@using System.Text.Json
@using System.Text.Json.Serialization
@using SCHQ_Blazor.Classes
@using System.Web
@using SCHQ_Blazor.Models
@using SCHQ_Blazor.Services
@using static SCHQ_Protos.SCHQ_Relations
@attribute [StreamRendering(false)]
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<Resource> Localizer
@inject SCHQ_Service SCHQ

<script>
  window.downloadFileFromStream = async (fileName, contentStreamReference) => {
    const arrayBuffer = await contentStreamReference.arrayBuffer();
    const blob = new Blob([arrayBuffer]);
    const url = URL.createObjectURL(blob);
    const anchorElement = document.createElement('a');
    anchorElement.href = url;
    anchorElement.download = fileName ?? '';
    anchorElement.click();
    anchorElement.remove();
    URL.revokeObjectURL(url);
  }
</script>

@if (IsAddMode) {
  <PageTitle>SCHQ Web > @Localizer["Add Channel"]</PageTitle>
  <h1>@Localizer["Add Channel"]</h1>
  <p>
    <div class="input-group">
      <div class="form-floating">
        <input type="text" class="form-control" id="floatingInputGroupChannel" placeholder="@Localizer["Channel Name"]*" @bind=Name @bind:event="oninput">
          <label for="floatingInputGroupChannel">@Localizer["Channel Name"]*</label>
        </div>
      </div>
    </p>
    <p>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="flexCheckIsLocalCache" @bind=IsLocalStorage @bind:event="oninput">
          <label class="form-check-label" for="flexCheckIsLocalCache">
            @Localizer["Local Storage"]
          </label>
        </div>
      </p>
    } else {
      <PageTitle>SCHQ Web > @Localizer["Manage Channel"] > @Localizer["Channel"]: @ChannelName</PageTitle>
      <h1>@ChannelName</h1>
      <p class="pb-2">
        <h5 class="mb-2 fw-bold">@Localizer["Authentication"]</h5>
        <div class="form-floating">
          <input type="password" class="form-control @(AdminPasswordValidated && !AdminPasswordCorrect ? "is-invalid" : string.Empty)" id="floatingInputGroupChannelPassword" placeholder="@Localizer["Admin Password"]*" @bind=AdminPassword @bind:event="oninput" @onblur="ValidateAdminPassword" @onkeydown="HandleAdminPasswordKeyDown">
            <label for="floatingInputGroupChannelPassword">@Localizer["Admin Password"]*</label>
            @if (AdminPasswordValidated && !AdminPasswordCorrect) {
              <div class="invalid-feedback">@Localizer["Access denied"]</div>
            }
          </div>
        </p>
        @if (AdminPasswordCorrect) {
          <h5 class="mb-2 fw-bold">@Localizer["Channel Information"]</h5>
          <p>
            <div class="input-group">
              <div class="form-floating">
                <input type="text" class="form-control @(string.IsNullOrWhiteSpace(NewChannelName) ? "border-danger" : string.Empty)" id="floatingInputGroupNewChannelName" placeholder="@Localizer["Channel Name"]*" @bind=NewChannelName @bind:event="oninput">
                  <label for="floatingInputGroupNewChannelName">@Localizer["Channel Name"]*</label>
                </div>
              </div>
            </p>
        }
        }
        <div hidden="@(IsAddMode ? IsLocalStorage : !AdminPasswordCorrect)">
          <p>
            <div class="input-group">
              <div class="form-floating">
                <input type="text" class="form-control" id="floatingInputGroupDescription" placeholder="@Localizer["Channel Description"]" @bind=Description @bind:event="oninput">
                  <label for="floatingInputGroupDescription">@Localizer["Channel Description"]</label>
                </div>
              </div>
            </p>
            @if (!IsAddMode) {
              <h5 class="mb-2 fw-bold">@Localizer["Discord Webhook URL"]</h5>
              <p>
                @if (HasDiscordWebhookUrl) {
                  <span class="badge text-bg-success mb-0">@Localizer["Webhook URL is configured"]</span>
                } else {
                  <span class="badge text-bg-secondary mb-0">@Localizer["No Webhook URL configured"]</span>
                }
              </p>
              <p>
                <div class="input-group">
                  <div class="form-floating">
                    <input type="password" class="form-control" id="floatingInputGroupDiscordWebhookUrl" placeholder="@Localizer["New Discord Webhook URL"]" @bind=DiscordWebhookUrl @bind:event="oninput">
                      <label for="floatingInputGroupDiscordWebhookUrl">@Localizer["New Discord Webhook URL"]</label>
                    </div>
                  </div>
                </p>
              } else {
                <p>
                  <div class="input-group">
                    <div class="form-floating">
                      <input type="url" class="form-control" id="floatingInputGroupDiscordWebhookUrl" placeholder="@Localizer["Discord Webhook URL"]" @bind=DiscordWebhookUrl @bind:event="oninput">
                        <label for="floatingInputGroupDiscordWebhookUrl">@Localizer["Discord Webhook URL"]</label>
                      </div>
                    </div>
                  </p>
                }
                <p>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="flexCheckIsPrivate" @bind=IsPrivate @bind:event="oninput">
                      <label class="form-check-label" for="flexCheckIsPrivate">
                        @Localizer["Private"]
                      </label>
                    </div>
                  </p>
                  @if (!IsAddMode) {
                    <h5 class="mb-2 fw-bold">@Localizer["Change Admin Password"]</h5>
                  }
                  <p>
                    <div class="form-floating mb-2">
                      <input type="password" class="form-control @(NewAdminPassword != ConfirmNewAdminPassword ? "border-danger" : string.Empty)" id="floatingInputGroupAdminPassword" placeholder="@(IsAddMode? Localizer["Admin Password"] + "*" : Localizer["New Admin Password"])" @bind=NewAdminPassword @bind:event="oninput">
                        <label for="floatingInputGroupAdminPassword">@(IsAddMode? Localizer["Admin Password"] + "*" : Localizer["New Admin Password"])</label>
                      </div>
                      <div class="form-floating">
                        <input type="password" class="form-control @(NewAdminPassword != ConfirmNewAdminPassword ? "border-danger" : string.Empty)" id="floatingInputGroupAdminPasswordConfirm" placeholder="@(IsAddMode? Localizer["Confirm Admin Password"] + "*" : Localizer["Confirm New Admin Password"])" @bind=ConfirmNewAdminPassword @bind:event="oninput">
                          <label for="floatingInputGroupAdminPasswordConfirm">@(IsAddMode? Localizer["Confirm Admin Password"] + "*" : Localizer["Confirm New Admin Password"])</label>
                        </div>
                      </p>
                      @if (!IsAddMode && AdminPasswordCorrect) {
                        <h5 class="mb-2 fw-bold">@Localizer["Tags"]</h5>
                        @if (Tags.Count > 0) {
                          <div class="mb-2 d-flex flex-wrap gap-2">
                            @foreach (var tag in Tags) {
                              @if (EditTagId == tag.Id) {
                                <div class="input-group input-group-sm">
                                  <input type="text" class="form-control" placeholder="@Localizer["Tag Value"]" @bind=EditTagValue @bind:event="oninput" />
                                  <input type="text" class="form-control" placeholder="@Localizer["Description"]" @bind=EditTagDescription @bind:event="oninput" />
                                  <div class="dropdown dropup @(EditTagColorOpen ? "show" : "")">
                                    <button class="btn btn-sm text-bg-@(EditTagColor.ToString().ToLower()) dropdown-toggle h-100" type="button" @onclick="() => EditTagColorOpen = !EditTagColorOpen">
                                      @Localizer["Color"]
                                    </button>
                                    <ul class="dropdown-menu p-1 @(EditTagColorOpen ? "show" : "")" style="min-width: 0; top: auto; bottom: 100%;">
                                      @foreach (TagColor color in Enum.GetValues<TagColor>()) {
                                        <li>
                                          <button class="btn btn-sm w-100 text-start text-bg-@(color.ToString().ToLower()) @(EditTagColor == color ? "fw-bold" : string.Empty) mb-1" type="button" @onclick="() => { EditTagColor = color; EditTagColorOpen = false; }">@Localizer["Color"]</button>
                                        </li>
                                      }
                                    </ul>
                                  </div>
                                  <button class="btn btn-success btn-sm" @onclick="() => SaveTag(tag.Id)" title="@Localizer["Save"]">
                                    <svg class="bi" width="12" height="12" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#floppy2-fill" />
                                    </svg>
                                  </button>
                                  <button class="btn btn-secondary btn-sm" @onclick="CancelEditTag" title="@Localizer["Cancel"]">
                                    <svg class="bi" width="12" height="12" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                                    </svg>
                                  </button>
                                </div>
                              } else {
                                <div class="d-inline-flex align-items-center gap-1">
                                  <span class="badge text-bg-@(tag.Color.ToString().ToLower())" title="@tag.Description">@tag.Value</span>
                                  <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => StartEditTag(tag)" title="@Localizer["Edit"]">
                                    <svg class="bi" width="10" height="10" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#pencil-square" />
                                    </svg>
                                  </button>
                                  <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => DeleteTag(tag.Id)" title="@Localizer["Delete"]">
                                    <svg class="bi" width="10" height="10" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                                    </svg>
                                  </button>
                                </div>
                              }
                            }
                          </div>
                        }
                        <p>
                          <div class="input-group">
                            <div class="form-floating">
                              <input type="text" class="form-control" id="floatingInputGroupTagValue" placeholder="@Localizer["Tag Value"]" @bind=NewTagValue @bind:event="oninput" />
                              <label for="floatingInputGroupTagValue">@Localizer["Tag Value"]</label>
                            </div>
                            <div class="form-floating">
                              <input type="text" class="form-control" id="floatingInputGroupTagDescription" placeholder="@Localizer["Description"]" @bind=NewTagDescription @bind:event="oninput" />
                              <label for="floatingInputGroupTagDescription">@Localizer["Description"]</label>
                            </div>
                            <div class="dropdown dropup @(NewTagColorOpen ? "show" : "")">
                              <button class="btn text-bg-@(NewTagColor.ToString().ToLower()) dropdown-toggle h-100" type="button" @onclick="() => NewTagColorOpen = !NewTagColorOpen">
                                @Localizer["Color"]
                              </button>
                              <ul class="dropdown-menu p-1 @(NewTagColorOpen ? "show" : "")" style="min-width: 0; top: auto; bottom: 100%;">
                                @foreach (TagColor color in Enum.GetValues<TagColor>()) {
                                  <li>
                                    <button class="btn btn-sm w-100 text-start text-bg-@(color.ToString().ToLower()) @(NewTagColor == color ? "fw-bold" : string.Empty) mb-1" type="button" @onclick="() => { NewTagColor = color; NewTagColorOpen = false; }">@Localizer["Color"]</button>
                                  </li>
                                }
                              </ul>
                            </div>
                            <button class="btn btn-primary" @onclick="AddTag" disabled="@string.IsNullOrWhiteSpace(NewTagValue)" title="@Localizer["Add Tag"]">
                              <svg class="bi" width="16" height="16" fill="currentColor">
                                <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#plus-lg" />
                              </svg>
                            </button>
                          </div>
                        </p>
                        <h5 class="mb-2 fw-bold">@Localizer["Users"]</h5>
                        @if (Users.Count > 0) {
                          <div class="mb-2 d-flex flex-wrap gap-2">
                            @foreach (var user in Users) {
                              @if (EditUserId == user.Id) {
                                <div class="input-group input-group-sm">
                                  <input type="password" class="form-control @(EditUserPassword != EditUserPasswordConfirm ? "border-danger" : string.Empty)" placeholder="@Localizer["User Password"]" @bind=EditUserPassword @bind:event="oninput" />
                                  <input type="password" class="form-control @(EditUserPassword != EditUserPasswordConfirm ? "border-danger" : string.Empty)" placeholder="@Localizer["Confirm User Password"]" @bind=EditUserPasswordConfirm @bind:event="oninput" />
                                  <select class="form-select" @bind=EditUserPermissions>
                                    <option value="@ChannelPermissions.Read">@Localizer["Read"]</option>
                                    <option value="@ChannelPermissions.Write">@Localizer["Write"]</option>
                                  </select>
                                  <button class="btn btn-success btn-sm" @onclick="() => SaveUser(user.Id)" disabled="@(EditUserPassword != EditUserPasswordConfirm)" title="@Localizer["Save"]">
                                    <svg class="bi" width="12" height="12" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#floppy2-fill" />
                                    </svg>
                                  </button>
                                  <button class="btn btn-secondary btn-sm" @onclick="CancelEditUser" title="@Localizer["Cancel"]">
                                    <svg class="bi" width="12" height="12" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                                    </svg>
                                  </button>
                                </div>
                              } else {
                                <div class="d-inline-flex align-items-center gap-1">
                                  <span class="badge text-bg-@(user.Permissions == ChannelPermissions.Write ? "primary" : "secondary")" title="@(user.Permissions == ChannelPermissions.Write ? Localizer["Write"] : Localizer["Read"])">@user.Username</span>
                                  <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => StartEditUser(user)" title="@Localizer["Edit"]">
                                    <svg class="bi" width="10" height="10" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#pencil-square" />
                                    </svg>
                                  </button>
                                  <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => DeleteUser(user.Id)" title="@Localizer["Delete"]">
                                    <svg class="bi" width="10" height="10" fill="currentColor">
                                      <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                                    </svg>
                                  </button>
                                </div>
                              }
                            }
                          </div>
                        }
                        <p>
                          <div class="input-group">
                            <div class="form-floating">
                              <input type="text" class="form-control" id="floatingInputGroupUsername" placeholder="@Localizer["Username"]" @bind=NewUsername @bind:event="oninput" />
                              <label for="floatingInputGroupUsername">@Localizer["Username"]</label>
                            </div>
                            <div class="form-floating">
                              <input type="password" class="form-control @(NewUserPassword != NewUserPasswordConfirm ? "border-danger" : string.Empty)" id="floatingInputGroupUserPassword" placeholder="@Localizer["User Password"]" @bind=NewUserPassword @bind:event="oninput" />
                              <label for="floatingInputGroupUserPassword">@Localizer["User Password"]</label>
                            </div>
                            <div class="form-floating">
                              <input type="password" class="form-control @(NewUserPassword != NewUserPasswordConfirm ? "border-danger" : string.Empty)" id="floatingInputGroupUserPasswordConfirm" placeholder="@Localizer["Confirm User Password"]" @bind=NewUserPasswordConfirm @bind:event="oninput" />
                              <label for="floatingInputGroupUserPasswordConfirm">@Localizer["Confirm User Password"]</label>
                            </div>
                            <select class="form-select" @bind=NewUserPermissions>
                              <option value="@ChannelPermissions.Read">@Localizer["Read"]</option>
                              <option value="@ChannelPermissions.Write">@Localizer["Write"]</option>
                            </select>
                            <button class="btn btn-primary" @onclick="AddUser" disabled="@(string.IsNullOrWhiteSpace(NewUsername) || string.IsNullOrWhiteSpace(NewUserPassword) || NewUserPassword != NewUserPasswordConfirm)" title="@Localizer["Add User"]">
                              <svg class="bi" width="16" height="16" fill="currentColor">
                                <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#plus-lg" />
                              </svg>
                            </button>
                          </div>
                        </p>
                      }
                    </div>
                    <p>
                      <div class="alert alert-danger" role="alert" hidden="@(ErrorText == null)">
                        <i>@ErrorText</i>
                      </div>
                    </p>
                    @if (IsAddMode) {
                      <p><button type="button" class="btn btn-primary" @onclick="Add" disabled="@ButtonIsDisabled">@Localizer["Add Channel"]</button></p>
                    } else if (AdminPasswordCorrect) {
                      <div class="btn-group mb-2">
                        <button type="button" class="btn btn-primary" @onclick="UpdateChannel" disabled="@ButtonIsDisabled" title="@Localizer["Save"]">
                          <svg class="bi" width="16" height="16" fill="currentColor">
                            <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#floppy2-fill" />
                          </svg>
                          @Localizer["Channel"]
                        </button>
                        <button type="button" class="btn btn-danger" @onclick="DeleteChannel" title="@Localizer["Delete Channel"]">
                          <svg class="bi" width="16" height="16" fill="currentColor">
                            <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                          </svg>
                        </button>
                      </div>
                      <div class="btn-group mb-2">
                        <button type="button" class="btn btn-primary" @onclick="DownloadRelations" disabled="@IsBusy" title="@Localizer["Download Relations"]">
                          <svg class="bi" width="16" height="16" fill="currentColor">
                            <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#download" />
                          </svg>
                          @Localizer["Relations"]
                        </button>
                        <label class="btn btn-primary" style="display: inline-flex; align-items: center; background-color: @(IsBusy ? "#61A1FE" : "#1B6EC2");" for="input-file" disabled="@IsBusy" title="@Localizer["Upload Relations"]">
                          <svg class="bi" width="16" height="16" fill="currentColor">
                            <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#upload" />
                          </svg>
                        </label>
                        <button type="button" class="btn btn-danger" @onclick="DeleteRelations" title="@Localizer["Delete Relations"]">
                          <svg class="bi" width="16" height="16" fill="currentColor">
                            <use xlink:href="/lib/bootstrap-icons/bootstrap-icons.svg#x-lg" />
                          </svg>
                        </button>
                      </div>
                      <InputFile OnChange="@UploadRelations" accept="text/csv,application/json" id="input-file" disabled="@IsBusy" multiple hidden />
                    }

@code {
  [Parameter]
  public string? ChannelName { get; set; }
  private bool IsAddMode => string.IsNullOrWhiteSpace(ChannelName) || Navigation.Uri.Contains("/addchannel", StringComparison.OrdinalIgnoreCase);

  private string? _name;
  [SupplyParameterFromQuery]
  public string? Name {
    get { return _name; }
    set {
      _name = value;
      ButtonIsDisabled = CheckButtonIsDisabled;
    }
  }
  private string? _newChannelName = string.Empty;
  private string? NewChannelName {
    get { return _newChannelName; }
    set {
      _newChannelName = value;
      ButtonIsDisabled = CheckButtonIsDisabled;
    }
  }
  public ChannelInfo? ChannelInformation { get; set; }
  private string? _adminPassword = string.Empty;
  private string? AdminPassword {
    get { return _adminPassword; }
    set {
      _adminPassword = value;
      AdminPasswordValidated = false;
      AdminPasswordCorrect = false;
    }
  }
  private bool AdminPasswordValidated { get; set; }
  private bool AdminPasswordCorrect { get; set; }
  private string? _newAdminPassword = string.Empty;
  private string? NewAdminPassword {
    get { return _newAdminPassword; }
    set {
      _newAdminPassword = value;
      ButtonIsDisabled = CheckButtonIsDisabled;
    }
  }
  private string? _confirmNewAdminPassword = string.Empty;
  private string? ConfirmNewAdminPassword {
    get { return _confirmNewAdminPassword; }
    set {
      _confirmNewAdminPassword = value;
      ButtonIsDisabled = CheckButtonIsDisabled;
    }
  }

  private string? Description { get; set; }
  private string? DiscordWebhookUrl { get; set; }
  private bool HasDiscordWebhookUrl { get; set; }
  private bool _isLocalStorage;
  private bool IsLocalStorage {
    get { return _isLocalStorage; }
    set {
      _isLocalStorage = value;
      ButtonIsDisabled = CheckButtonIsDisabled;
    }
  }
  private bool IsPrivate { get; set; }
  private bool ButtonIsDisabled { get; set; } = true;
  private bool CheckButtonIsDisabled {
    get {
      if (IsAddMode) {
        return string.IsNullOrWhiteSpace(Name) || (!IsLocalStorage && (string.IsNullOrWhiteSpace(NewAdminPassword) || NewAdminPassword != ConfirmNewAdminPassword));
      }
      return NewAdminPassword != ConfirmNewAdminPassword
        || string.IsNullOrWhiteSpace(NewChannelName);
    }
  }
  private bool IsBusy { get; set; }
  private string? ErrorText { get; set; }

  protected override async Task OnInitializedAsync() {
    if (!IsAddMode) {
      ChannelReply reply = await SCHQ.GetChannel(new() { Channel = ChannelName });
      if (reply != null && reply.Found && string.Equals(reply.Channel?.Name, ChannelName, StringComparison.OrdinalIgnoreCase)) {
        ChannelName = reply.Channel!.Name;
        ChannelInformation = reply?.Channel;
        Description = reply?.Channel?.Description ?? string.Empty;
        NewChannelName = ChannelName;
        IsPrivate = reply?.Channel?.Private ?? false;
        HasDiscordWebhookUrl = !string.IsNullOrWhiteSpace(reply?.Channel?.DiscordWebhookUrl);
        DiscordWebhookUrl = string.Empty;
      }
    }
    ButtonIsDisabled = CheckButtonIsDisabled;
    StateHasChanged();
  }

  private async Task HandleAdminPasswordKeyDown(KeyboardEventArgs e) {
    if (e.Key == "Enter") await ValidateAdminPassword();
  }

  private async Task ValidateAdminPassword() {
    AdminPasswordCorrect = await SCHQ.ValidateAdminPassword(ChannelName, AdminPassword);
    AdminPasswordValidated = !string.IsNullOrWhiteSpace(AdminPassword);
    if (AdminPasswordCorrect) {
      if (Users?.Count == 0) await LoadUsers();
      if (Tags?.Count == 0) await LoadTags();
    }
  }

  private async void Add() {
    ErrorText = null;
    StateHasChanged();
    if (!string.IsNullOrWhiteSpace(Name)) {
      if (!IsLocalStorage) {
        SuccessReply reply = await SCHQ.AddChannel(new() {
          Channel = Name,
          Description = Description,
          AdminPassword = NewAdminPassword ?? string.Empty,
          Private = IsPrivate,
          DiscordWebhookUrl = DiscordWebhookUrl ?? string.Empty
        });
        if (reply.Success) {
          Navigation.NavigateTo($"/channel/{Uri.EscapeDataString(Name)}");
        } else {
          ErrorText = reply.Info;
          StateHasChanged();
        }
      } else {
        string[] channels = [];
        string? channelsJson = await LocalStorageService.GetValue(JS, "channels");
        if (!string.IsNullOrWhiteSpace(channelsJson)) {
          channels = JsonSerializer.Deserialize<string[]>(channelsJson) ?? [];
        }
        if (!channels.Any(c => c.Equals(Name, StringComparison.InvariantCultureIgnoreCase))) {
          channels = channels.Append(Name).ToArray();
          await LocalStorageService.SetValue(JS, "channels", JsonSerializer.Serialize(channels, new JsonSerializerOptions() { DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull }));
          Navigation.NavigateTo($"/localchannel/{Uri.EscapeDataString(Name)}");
        } else {
          ErrorText = Localizer["Channel already exists"];
          StateHasChanged();
        }
      }
    }
  }

  private async void UpdateChannel() {
    ErrorText = null;
    SuccessReply reply = await SCHQ.UpdateChannel(new() {
      Channel = ChannelName,
      NewChannelName = NewChannelName,
      Description = Description,
      AdminPassword = AdminPassword,
      NewAdminPassword = NewAdminPassword,
      NewAdminPasswordConfirm = ConfirmNewAdminPassword,
      Private = IsPrivate,
      DiscordWebhookUrl = DiscordWebhookUrl ?? string.Empty
    });
    if (reply.Success) {
      Navigation.NavigateTo("/", true);
    } else {
      ErrorText = reply.Info;
      StateHasChanged();
    }
  }

  private async void DeleteChannel() {
    ErrorText = null;
    bool confirmed = await JS.InvokeAsync<bool>("confirm", $"{Localizer["Channel"]} [{ChannelName}]:{Environment.NewLine}{Localizer["Do you really want to delete the channel?"]}");
    if (confirmed) {
      SuccessReply reply = await SCHQ.RemoveChannel(new() { Channel = ChannelName, AdminPassword = AdminPassword ?? string.Empty });
      if (reply.Success) {
        await LocalStorageService.RemoveValue(JS, $"pwd{ChannelName}");
        Navigation.NavigateTo("/", true);
      } else {
        ErrorText = reply.Info;
        StateHasChanged();
      }
    }
  }

  private async Task DownloadRelations() {
    ErrorText = null;
    IsBusy = true;
    StateHasChanged();
    RelationsReply reply = await SCHQ.GetRelations(new() {
      Channel = ChannelName,
      Password = AdminPassword ?? string.Empty
    });
    if (reply?.Relations?.Count > 0) {
      try {
        using MemoryStream relationsStream = new();
        JsonSerializer.Serialize<RelationInfo[]>(relationsStream, reply.Relations.ToArray() ?? [],
          new JsonSerializerOptions() {
            DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingDefault,
            WriteIndented = true
          });
        using var streamRef = new DotNetStreamReference(relationsStream);
        streamRef.Stream.Position = 0;
        await JS.InvokeVoidAsync("downloadFileFromStream", $"SCHQ_Web_Relations_{ChannelName}_{DateTime.Now:yyyyMMdd_HHmmss}.json", streamRef);
      } catch (Exception ex) {
        ErrorText = $"{Localizer["Exception"]}: {ex.Message}, {Localizer["Inner Exception"]}: {ex.InnerException?.Message ?? Localizer["Empty"]}";
      }
    } else {
      ErrorText = !string.IsNullOrWhiteSpace(reply?.Info) ? reply.Info : Localizer["No relations found"];
    }
    IsBusy = false;
    StateHasChanged();
  }

  private async Task UploadRelations(InputFileChangeEventArgs e) {
    ErrorText = null;
    StateHasChanged();
    try {
      switch (e.File?.ContentType) {
        case "application/json": {
            string reader = await new StreamReader(e.File.OpenReadStream()).ReadToEndAsync();
            if (reader?.Length > 0) {
              List<RelationInfo> relations = JsonSerializer.Deserialize<RelationInfo[]>(reader)?.Where(r => !string.IsNullOrWhiteSpace(r.Name)).ToList() ?? [];
              if (relations?.Count > 0) {
                if (await SetRelations(relations)) {
                  Navigation.NavigateTo($"/channel/{Uri.EscapeDataString(ChannelName!)}");
                }
              } else {
                ErrorText = Localizer["No relations found"];
              }
            } else {
              ErrorText = Localizer["File is empty"];
            }
            break;
          }
        case "text/csv": {
            string reader = await new StreamReader(e.File.OpenReadStream()).ReadToEndAsync();
            if (reader?.Length > 0) {
              string[] fields;
              List<RelationInfo> relations = [];
              RelationInfo relation;
              foreach (string line in reader.Split(Environment.NewLine)) {
                fields = line.Split(';');
                if (!string.IsNullOrWhiteSpace(fields[0])) {
                  relation = new() {
                    Name = fields[0]
                  };
                  if (fields.Length > 1 && int.TryParse(fields[1], out int relVal)) {
                    relation.Relation = (RelationValue)relVal;
                  }
                  if (fields.Length > 2 && int.TryParse(fields[2], out int relType)) {
                    relation.Type = (RelationType)relType;
                  }
                  if (fields.Length > 3 && fields[3] != null) {
                    relation.Comment = fields[3];
                  }
                  relations.Add(relation);
                }
              }
              if (relations.Count > 0) {
                if (await SetRelations(relations)) {
                  Navigation.NavigateTo($"/channel/{Uri.EscapeDataString(ChannelName!)}");
                }
              } else {
                ErrorText = Localizer["No relations found"];
              }
            } else {
              ErrorText = Localizer["File is empty"];
            }
            break;
          }
        default:
          ErrorText = $"{Localizer["File type not supported"]}: [{e.File?.ContentType}]";
          break;
      }
    } catch (Exception ex) {
      ErrorText = $"{Localizer["Exception"]}: {ex.Message}, {Localizer["Inner Exception"]}: {ex.InnerException?.Message ?? Localizer["Empty"]}";
    }
    StateHasChanged();
  }

  private async Task<bool> SetRelations(List<RelationInfo> relations) {
    bool success = false;

    SetRelationsRequest request = new() {
      Channel = ChannelName,
      Password = AdminPassword ?? string.Empty,
    };
    request.Relations.AddRange(relations);
    SuccessReply reply = await SCHQ.SetRelations(request);
    success = reply.Success;
    if (!success) {
      ErrorText = reply.Info ?? Localizer["Unknown error"];
    }

    return success;
  }

  private async void DeleteRelations() {
    ErrorText = null;
    bool confirmed = await JS.InvokeAsync<bool>("confirm", $"{Localizer["Channel"]} [{ChannelName}]:{Environment.NewLine}{Localizer["Do you really want to delete all relations?"]}");
    if (confirmed) {
      SuccessReply reply = await SCHQ.RemoveRelations(new() { Channel = ChannelName, AdminPassword = AdminPassword ?? string.Empty });
      if (reply.Success) {
        Navigation.NavigateTo($"/channel/{ChannelName}", true);
      } else {
        ErrorText = reply.Info;
        StateHasChanged();
      }
    }
  }

  private List<Tag> Tags { get; set; } = [];
  private string? NewTagValue { get; set; }
  private string? NewTagDescription { get; set; }
  private TagColor NewTagColor { get; set; } = TagColor.Secondary;
  private bool NewTagColorOpen { get; set; }
  private int EditTagId { get; set; }
  private string? EditTagValue { get; set; }
  private string? EditTagDescription { get; set; }
  private TagColor EditTagColor { get; set; } = TagColor.Secondary;
  private bool EditTagColorOpen { get; set; }

  private async Task LoadTags() {
    Tags = await SCHQ.GetTags(ChannelName ?? string.Empty);
    StateHasChanged();
  }

  private async void AddTag() {
    if (!string.IsNullOrWhiteSpace(NewTagValue)) {
      SuccessReply reply = await SCHQ.AddTag(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, NewTagValue, NewTagDescription, NewTagColor);
      if (reply.Success) {
        NewTagValue = null;
        NewTagDescription = null;
        NewTagColor = TagColor.Secondary;
        await LoadTags();
      } else {
        ErrorText = reply.Info;
        StateHasChanged();
      }
    }
  }

  private void StartEditTag(Tag tag) {
    EditTagId = tag.Id;
    EditTagValue = tag.Value;
    EditTagDescription = tag.Description;
    EditTagColor = tag.Color;
    EditTagColorOpen = false;
  }

  private void CancelEditTag() {
    EditTagId = 0;
    EditTagValue = null;
    EditTagDescription = null;
    EditTagColor = TagColor.Secondary;
    EditTagColorOpen = false;
  }

  private async void SaveTag(int tagId) {
    if (!string.IsNullOrWhiteSpace(EditTagValue)) {
      SuccessReply reply = await SCHQ.UpdateTag(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, tagId, EditTagValue, EditTagDescription, EditTagColor);
      if (reply.Success) {
        CancelEditTag();
        await LoadTags();
      } else {
        ErrorText = reply.Info;
        StateHasChanged();
      }
    }
  }

  private async void DeleteTag(int tagId) {
    SuccessReply reply = await SCHQ.RemoveTag(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, tagId);
    if (reply.Success) {
      await LoadTags();
    } else {
      ErrorText = reply.Info;
      StateHasChanged();
    }
  }

  private List<User> Users { get; set; } = [];
  private string? NewUsername { get; set; }
  private string? NewUserPassword { get; set; }
  private string? NewUserPasswordConfirm { get; set; }
  private ChannelPermissions NewUserPermissions { get; set; } = ChannelPermissions.Read;
  private int EditUserId { get; set; }
  private string? EditUserPassword { get; set; }
  private string? EditUserPasswordConfirm { get; set; }
  private ChannelPermissions EditUserPermissions { get; set; } = ChannelPermissions.Read;

  private async Task LoadUsers() {
    Users = await SCHQ.GetUsers(ChannelName ?? string.Empty, AdminPassword ?? string.Empty);
    StateHasChanged();
  }

  private void StartEditUser(User user) {
    EditUserId = user.Id;
    EditUserPassword = string.Empty;
    EditUserPasswordConfirm = string.Empty;
    EditUserPermissions = user.Permissions;
  }

  private void CancelEditUser() {
    EditUserId = 0;
    EditUserPassword = null;
    EditUserPasswordConfirm = null;
    EditUserPermissions = ChannelPermissions.Read;
  }

  private async void SaveUser(int userId) {
    SuccessReply reply = await SCHQ.UpdateUser(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, userId, EditUserPassword, EditUserPermissions);
    if (reply.Success) {
      CancelEditUser();
      await LoadUsers();
    } else {
      ErrorText = reply.Info;
      StateHasChanged();
    }
  }

  private async void DeleteUser(int userId) {
    SuccessReply reply = await SCHQ.RemoveUser(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, userId);
    if (reply.Success) {
      await LoadUsers();
    } else {
      ErrorText = reply.Info;
      StateHasChanged();
    }
  }

  private async void AddUser() {
    if (!string.IsNullOrWhiteSpace(NewUsername)) {
      SuccessReply reply = await SCHQ.AddUser(ChannelName ?? string.Empty, AdminPassword ?? string.Empty, NewUsername, NewUserPassword ?? string.Empty, NewUserPermissions);
      if (reply.Success) {
        NewUsername = null;
        NewUserPassword = null;
        NewUserPasswordConfirm = null;
        NewUserPermissions = ChannelPermissions.Read;
        await LoadUsers();
      } else {
        ErrorText = reply.Info;
        StateHasChanged();
      }
    }
  }

}
